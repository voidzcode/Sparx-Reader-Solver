{
  "manifest_version": 3,
  "name": "Sparx Reader Copy Unblocker",
  "version": "1.12",
  "description": "Fixes text selection and copying on Sparx Reader.",
  "icons": {
    "128": "icon.svg"
  },
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [
        "*://*.sparxreader.co.uk/*",
        "*://reader.sparx-learning.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
